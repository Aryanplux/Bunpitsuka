{
    "name": "Bunpitsuka - Email with AI",
    "description": "Bunpitsuka is an AI-powered email assistant that helps you write emails faster and more efficiently. With Bunpitsuka, you can generate email drafts, get suggestions for improving your writing, and even automate responses to common emails.",
    "version": "1.0",
    "manifest_version": 3,
    "permissions": [
        "activeTab",
        "storage"
    ],
    "host_permissions": [
        "https://localhost:8081/*",
        "*://mail.google.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "*://mail.google.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ],
            "run_at": "document_end"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "icons/*"
            ],
            "matches": [
                "*://mail.google.com/*"
            ]
        }
    ],
    "icons": {
        "16": "icons/icon.png",
        "48": "icons/icon.png",
        "128": "icons/icon.png"
    },
    "action": {
        "default_title": "Bunpitsuka - Email with AI",
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon.png",
            "48": "icons/icon.png",
            "128": "icons/icon.png"
        }
    }
}